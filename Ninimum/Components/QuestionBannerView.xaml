<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Samokat.Components.QuestionBannerView">

    <Grid>

        <!-- Background -->
        <Grid>
            <BoxView Color="White" />

            <!-- Red diagonal -->
            <Grid>
                <BoxView Color="#E53935" />
                <Grid.Clip>
                    <PathGeometry>
                        <PathFigure StartPoint="0,0">
                            <LineSegment Point="0,200" />
                            <LineSegment Point="200,0" />
                        </PathFigure>
                    </PathGeometry>
                </Grid.Clip>
            </Grid>
        </Grid>

        <!-- Content (Icon + Text) -->
        <VerticalStackLayout
            Spacing="6"
            HorizontalOptions="Center"
            VerticalOptions="Center">

            <Image
                Source="ic_question.png"
                WidthRequest="32"
                HeightRequest="32" />

            <Label
                Text="{Binding BannerText}"
                TextColor="Black"
                FontSize="14"
                HorizontalTextAlignment="Center" />

        </VerticalStackLayout>

    </Grid>

</ContentView>