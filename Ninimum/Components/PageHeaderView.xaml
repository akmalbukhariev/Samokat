<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Ninimum.Components.PageHeaderView"
    x:Name="this">

    <Grid
        HeightRequest="29"
        VerticalOptions="Start"
        HorizontalOptions="Fill">

        <!-- Left back button -->
        <Grid
            WidthRequest="35"
            HeightRequest="35"
            VerticalOptions="Center"
            HorizontalOptions="Start"
            Margin="0,4.44,0,0">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer
                    NumberOfTapsRequired="1"
                    Tapped="Back_Tapped" />
            </Grid.GestureRecognizers>

            <Image
                x:Name="imBack"
                Source="left_back.png"
                IsVisible="{Binding ShowBack, Source={x:Reference this}}"
                BackgroundColor="Transparent"
                VerticalOptions="Center"
                WidthRequest="20"
                HeightRequest="20" />
        </Grid>
        
        <!-- Title -->
        <Label
            Text="{Binding Title, Source={x:Reference this}}"
            HorizontalTextAlignment="Center"
            VerticalTextAlignment="Center"
            TextColor="#22292F"
            FontSize="24"
            FontFamily="{StaticResource FontSFMedium}"
            CharacterSpacing="0.24"
            HorizontalOptions="Center"
            VerticalOptions="Center" />

        <!-- Right icon -->
        <Grid
            WidthRequest="35"
            HeightRequest="35"
            VerticalOptions="Center"
            HorizontalOptions="End"
            Margin="0,4.44,5,0">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer
                    NumberOfTapsRequired="1"
                    Tapped="RightImage_Tapped" />
            </Grid.GestureRecognizers>

            <Image
                x:Name="imRightImage"
                Source="{Binding RightImage, Source={x:Reference this}}"
                IsVisible="{Binding ShowRightIcon, Source={x:Reference this}}"
                BackgroundColor="Transparent"
                VerticalOptions="Center"
                WidthRequest="20"
                HeightRequest="20" />
        </Grid>
    </Grid>
</ContentView>