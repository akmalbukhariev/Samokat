<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Samokat.Components.CustomRadioButtonView"
    x:Name="this">

    <HorizontalStackLayout Spacing="14" VerticalOptions="Center">
        <Grid WidthRequest="24" HeightRequest="24">
            <!-- Outer circle -->
            <Border
                WidthRequest="24"
                HeightRequest="24"
                Stroke="{Binding OuterStrokeColor, Source={x:Reference this}}"
                StrokeThickness="2"
                BackgroundColor="Transparent"
                StrokeShape="RoundRectangle 12" />

            <!-- Inner selected circle -->
            <Border
                WidthRequest="12"
                HeightRequest="12"
                BackgroundColor="{Binding SelectedColor, Source={x:Reference this}}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 6"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                IsVisible="{Binding IsSelected, Source={x:Reference this}}" />
        </Grid>

        <Label
            Text="{Binding Text, Source={x:Reference this}}"
            TextColor="{Binding TextColor, Source={x:Reference this}}"
            FontSize="{Binding FontSize, Source={x:Reference this}}"
            FontFamily="{Binding FontFamily, Source={x:Reference this}}"
            VerticalTextAlignment="Center"
            CharacterSpacing="0.17" />
    </HorizontalStackLayout>

    <ContentView.GestureRecognizers>
        <TapGestureRecognizer Tapped="OnTapped" />
    </ContentView.GestureRecognizers>
</ContentView>