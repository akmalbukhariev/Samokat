<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:components="clr-namespace:Ninimum.Components"
    x:Class="Ninimum.Components.SelectionPopup"
    x:Name="ThisPopup"
    CanBeDismissedByTappingOutsideOfPopup="True">

    <Border x:Name="PopupBorder"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            BackgroundColor="White"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 28"
            Padding="0">

        <ScrollView x:Name="PopupScroll">
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Items}"
                                 Spacing="0">

                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <components:SelectionPopupItemView
                            Text="{Binding Text}"
                            LeftImage="{Binding LeftImage}"
                            RightImage="{Binding RightImage}">
                            <components:SelectionPopupItemView.GestureRecognizers>
                                <TapGestureRecognizer
                                    Tapped="OnItemTapped"
                                    CommandParameter="{Binding .}" />
                            </components:SelectionPopupItemView.GestureRecognizers>
                        </components:SelectionPopupItemView>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>

            </VerticalStackLayout>
        </ScrollView>
    </Border>
</toolkit:Popup>