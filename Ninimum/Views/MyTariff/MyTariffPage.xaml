<?xml version="1.0" encoding="utf-8" ?>
<page:BasePage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:page="clr-namespace:Ninimum.Views"
    xmlns:components="clr-namespace:Ninimum.Components"
    x:Class="Ninimum.Views.MyTariff.MyTariffPage"
    x:Name="ThisPage"
    BackgroundColor="White">

    <page:BasePage.Resources>
        <ResourceDictionary>
            <Style x:Key="TariffLabelStyle" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource FontSFRegular}" />
                <Setter Property="FontSize" Value="17" />
                <Setter Property="TextColor" Value="#96979B" />
            </Style>

            <Style x:Key="TariffValueStyle" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource FontSFMedium}" />
                <Setter Property="FontSize" Value="17" />
                <Setter Property="TextColor" Value="#22292F" />
            </Style>
        </ResourceDictionary>
    </page:BasePage.Resources>

    <Grid RowDefinitions="Auto,*">

        <components:PageHeaderView
            Grid.Row="0"
            Title="Mening tarifim" />

        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="20,24,20,24" Spacing="24">

                <!-- Current tariff -->
                <Border
                    Padding="10"
                    BackgroundColor="White"
                    Stroke="#F78A08"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 10">

                    <VerticalStackLayout Spacing="14">

                        <HorizontalStackLayout Spacing="10">
                            <Label Text="Tarif rejasi" Style="{StaticResource TariffLabelStyle}" />
                            <Label Text="Gold" Style="{StaticResource TariffValueStyle}" />
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="10">
                            <Label Text="Azo bo’lgan sana" Style="{StaticResource TariffLabelStyle}" />
                            <Label Text="26.03.2026" Style="{StaticResource TariffValueStyle}" />
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="10">
                            <Label Text="Tarif tugashiga" Style="{StaticResource TariffLabelStyle}" />
                            <Label Text="29 kun qoldi" Style="{StaticResource TariffValueStyle}" />
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="10">
                            <Label Text="Narxi" Style="{StaticResource TariffLabelStyle}" />
                            <Label Text="99 000 so’m" Style="{StaticResource TariffValueStyle}" />
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="10">
                            <Label Text="Keyingi yechish sanasi" Style="{StaticResource TariffLabelStyle}" />
                            <Label Text="25.04.2026" Style="{StaticResource TariffValueStyle}" />
                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- History header -->
                <VerticalStackLayout
                    IsVisible="{Binding HasHistory}"
                    Spacing="10">

                    <HorizontalStackLayout
                        HorizontalOptions="Center"
                        Spacing="14">

                        <HorizontalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleHistoryCommand}" />
                        </HorizontalStackLayout.GestureRecognizers>

                        <Label
                            Text="Tarixdagi tariflar"
                            FontFamily="{StaticResource FontSFMedium}"
                            FontSize="15"
                            TextColor="#96979B"
                            VerticalOptions="Center" />

                        <Image
                            Source="{Binding HistoryArrowIcon}"
                            WidthRequest="24"
                            HeightRequest="24"
                            VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!-- Dynamic list -->
                    <CollectionView
                        ItemsSource="{Binding TariffHistory}"
                        IsVisible="{Binding IsHistoryVisible}"
                        SelectionMode="None">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Padding="10"
                                    Margin="0,0,0,10"
                                    BackgroundColor="#F7F8FB"
                                    Stroke="#DADADA"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10">

                                    <VerticalStackLayout Spacing="14">

                                        <HorizontalStackLayout Spacing="10">
                                            <Label Text="Tarif rejasi" Style="{StaticResource TariffLabelStyle}" />
                                            <Label Text="{Binding Plan}" Style="{StaticResource TariffValueStyle}" />
                                        </HorizontalStackLayout>

                                        <HorizontalStackLayout Spacing="10">
                                            <Label Text="Azo bo’lgan sana" Style="{StaticResource TariffLabelStyle}" />
                                            <Label Text="{Binding StartDate}" Style="{StaticResource TariffValueStyle}" />
                                        </HorizontalStackLayout>

                                        <HorizontalStackLayout Spacing="10">
                                            <Label Text="Azolik tugagan sana" Style="{StaticResource TariffLabelStyle}" />
                                            <Label Text="{Binding EndDate}" Style="{StaticResource TariffValueStyle}" />
                                        </HorizontalStackLayout>

                                        <HorizontalStackLayout Spacing="10">
                                            <Label Text="Narxi" Style="{StaticResource TariffLabelStyle}" />
                                            <Label Text="{Binding Price}" Style="{StaticResource TariffValueStyle}" />
                                        </HorizontalStackLayout>

                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</page:BasePage>