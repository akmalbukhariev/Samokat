<?xml version="1.0" encoding="utf-8" ?>
<page:BasePage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:page="clr-namespace:Ninimum.Views"
    xmlns:components="clr-namespace:Ninimum.Components"
    x:Class="Ninimum.Views.Children.ChildInfoPage"
    BackgroundColor="White">

    <Grid RowDefinitions="Auto,*,Auto"
          Padding="0,10,0,24">

        <components:PageHeaderView
            Grid.Row="0"
            Title="{Binding PageTitle}" />

        <ScrollView Grid.Row="1">
            <VerticalStackLayout
                Padding="28,34,28,0"
                Spacing="26">

                <Grid ColumnDefinitions="*,*"
                      Margin="40,0,40,10">

                    <components:CustomRadioButtonView
                        Grid.Column="0"
                        Text="O’g’il"
                        IsSelected="{Binding IsBoySelected}"
                        Command="{Binding SelectGenderCommand}"
                        CommandParameter="boy"
                        SelectedColor="#21C940"
                        UnselectedColor="#96979B"
                        TextColor="#22292F"
                        FontSize="17"
                        FontFamily="{StaticResource FontSFRegular}"
                        HorizontalOptions="Center" />

                    <components:CustomRadioButtonView
                        Grid.Column="1"
                        Text="Qiz"
                        IsSelected="{Binding IsGirlSelected}"
                        Command="{Binding SelectGenderCommand}"
                        CommandParameter="girl"
                        SelectedColor="#21C940"
                        UnselectedColor="#96979B"
                        TextColor="#22292F"
                        FontSize="17"
                        FontFamily="{StaticResource FontSFRegular}"
                        HorizontalOptions="Center" />
                </Grid>

                <components:InputView
                    Title="Ismi"
                    LeftIcon="ic_user.png"
                    Text="{Binding ChildFirstName}"
                    ClearButtonVisibility="WhileEditing" />

                <components:InputView
                    Title="Familiyasi"
                    LeftIcon="ic_user.png"
                    Text="{Binding ChildLastName}"
                    ClearButtonVisibility="WhileEditing" />

                <components:InputView
                    Title="Tug’ilgan kuni"
                    LeftIcon="ic_calendar.png"
                    Text="{Binding ChildBirthDate}"
                    ClearButtonVisibility="WhileEditing" />

                <Grid ColumnDefinitions="34,*"
                      ColumnSpacing="14"
                      Margin="6,18,0,0">

                    <Image
                        Source="ic_check.png"
                        WidthRequest="24"
                        HeightRequest="24"
                        VerticalOptions="Start"
                        Margin="0,4,0,0" />

                    <Label
                        Grid.Column="1"
                        Text="Barcha to’ldirilgan ma’lumotlar to’g’riligini kafolatlayman"
                        TextColor="#20262E"
                        FontSize="17"
                        FontFamily="{StaticResource FontSFRegular}"
                        LineBreakMode="WordWrap" />
                </Grid>

                <Label
                    Text="Begonaning ma’lumotlarini kiritish Qonun buzilishi oqibatiga olib kelishi mumkin."
                    TextColor="#9C9CA3"
                    FontSize="17"
                    FontFamily="{StaticResource FontSFRegular}"
                    HorizontalTextAlignment="Center"
                    LineBreakMode="WordWrap"
                    Margin="20,0,20,0" />

            </VerticalStackLayout>
        </ScrollView>

        <Button
            Grid.Row="2"
            Text="{Binding ButtonText}"
            BackgroundColor="#FF403B"
            TextColor="White"
            FontSize="18"
            FontFamily="{StaticResource FontSFMedium}"
            CornerRadius="10"
            HeightRequest="62"
            Margin="16,18,16,0"
            Command="{Binding SaveCommand}" />

    </Grid>
</page:BasePage>