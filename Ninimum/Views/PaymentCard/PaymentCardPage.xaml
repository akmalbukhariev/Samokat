<?xml version="1.0" encoding="utf-8" ?>
<page:BasePage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:page="clr-namespace:Ninimum.Views"
    xmlns:components="clr-namespace:Ninimum.Components"
    xmlns:converter="clr-namespace:Ninimum.Converter"
    x:Class="Ninimum.Views.PaymentCard.PaymentCardPage"
    x:Name="ThisPage"
    BackgroundColor="White">

    <page:BasePage.Resources>
        <ResourceDictionary>
            <converter:BoolToImageConverter x:Key="BoolToImageConverter"/>    
        </ResourceDictionary>
    </page:BasePage.Resources>
    
    <VerticalStackLayout Spacing="0">

        <components:PageHeaderView Title="To’lov kartalar" />

        <CollectionView
            ItemsSource="{Binding Cards}"
            SelectionMode="None"
            Margin="16,10,16,0"
            VerticalOptions="FillAndExpand">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame
                        Margin="0,0,0,16"
                        Padding="20"
                        CornerRadius="20"
                        BackgroundColor="#F7F8FB"
                        BorderColor="#DADADA"
                        HasShadow="False">

                        <VerticalStackLayout Spacing="20">

                            <Grid ColumnDefinitions="*,Auto">
                                <Label
                                    Text="Asosiy karta sifatida belgilanishi"
                                    FontFamily="{StaticResource FontSFRegular}"
                                    FontSize="15"
                                    TextColor="#96979B"
                                    VerticalOptions="Center" />

                                <Image
                                    Grid.Column="1"
                                    Source="{Binding IsPrimary, Converter={StaticResource BoolToImageConverter}}"
                                    WidthRequest="40"
                                    HeightRequest="24"
                                    VerticalOptions="Center">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.TogglePrimaryCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Image.GestureRecognizers>
                                </Image>
                            </Grid>

                            <BoxView HeightRequest="1" Color="#DADADA" />

                            <Grid ColumnDefinitions="*,120" ColumnSpacing="10">
                                <VerticalStackLayout Spacing="2">
                                    <Label
                                        Text="Karta raqami"
                                        FontFamily="{StaticResource FontSFRegular}"
                                        FontSize="15"
                                        TextColor="#96979B" />
                                    <Label
                                        Text="{Binding CardNumber}"
                                        FontFamily="{StaticResource FontSFMedium}"
                                        FontSize="18"
                                        TextColor="#22292F" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <Label
                                        Text="Amal qilishi"
                                        FontFamily="{StaticResource FontSFRegular}"
                                        FontSize="15"
                                        TextColor="#96979B" />
                                    <Label
                                        Text="{Binding ExpireDate}"
                                        FontFamily="{StaticResource FontSFMedium}"
                                        FontSize="18"
                                        TextColor="#22292F" />
                                </VerticalStackLayout>
                            </Grid>

                            <Frame
                                Padding="0"
                                HeightRequest="36"
                                CornerRadius="40"
                                BackgroundColor="#FFF2F3"
                                HasShadow="False">

                                <Grid ColumnDefinitions="Auto,Auto"
                                      HorizontalOptions="Center"
                                      ColumnSpacing="6"
                                      Padding="14,0"
                                      VerticalOptions="Center">

                                    <Image
                                        Source="ic_delete.png"
                                        WidthRequest="15"
                                        HeightRequest="15"
                                        VerticalOptions="Center" />

                                    <Label
                                        Grid.Column="1"
                                        Text="Kartani o‘chirib yuborish"
                                        FontFamily="{StaticResource FontSFMedium}"
                                        FontSize="15"
                                        TextColor="#FD473C"
                                        VerticalOptions="Center" />
                                </Grid>

                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.DeleteCardCommand}"
                                        CommandParameter="{Binding .}" />
                                </Frame.GestureRecognizers>
                            </Frame>

                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Frame
            Margin="16,10,16,20"
            HeightRequest="56"
            CornerRadius="40"
            BackgroundColor="#7CB518"
            HasShadow="False"
            Padding="0">

            <Frame.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding AddCardCommand}" />
            </Frame.GestureRecognizers>

            <HorizontalStackLayout
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Spacing="10">
                <Label Text="+"
                       FontSize="24"
                       TextColor="White"
                       VerticalOptions="Center" />
                <Label
                    Text="Yangi karta qo’shish"
                    FontFamily="{StaticResource FontSFMedium}"
                    FontSize="18"
                    TextColor="White"
                    VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Frame>

    </VerticalStackLayout>

</page:BasePage>