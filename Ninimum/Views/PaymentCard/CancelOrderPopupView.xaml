<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:ui="clr-namespace:Xe.AcrylicView;assembly=Xe.AcrylicView"
    x:Class="Samokat.Views.PaymentCard.CancelOrderPopupView"
    x:Name="ThisView"
    IsVisible="False">

    <Grid>

       <!-- 1. Blur layer -->
        <ui:AcrylicView
            HorizontalOptions="Fill"
            VerticalOptions="Fill"
            EffectStyle="Light"
            TintColor="White"
            TintOpacity="0.12" />

        <!-- 2. Dark overlay (THIS is your "Overlay") -->
        <Grid BackgroundColor="#66000000" />

        <Border
            WidthRequest="310"
            Padding="10"
            BackgroundColor="#CCFFFFFF"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 30"
            HorizontalOptions="Center"
            VerticalOptions="Center">

            <VerticalStackLayout Spacing="14">

                <VerticalStackLayout
                    Padding="20,10,20,0"
                    Spacing="10"
                    HorizontalOptions="Center">

                    <!-- Confirm icon -->
                    <Grid
                        IsVisible="{Binding IsSuccess, Source={x:Reference ThisView}, Converter={StaticResource InverseBoolConverter}}"
                        WidthRequest="140"
                        HeightRequest="140">

                        <Ellipse
                            Stroke="#96979B"
                            StrokeThickness="2.5"
                            WidthRequest="100"
                            HeightRequest="100"
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />

                        <Label
                            Text="?"
                            FontFamily="{StaticResource FontSFRegular}"
                            FontSize="58"
                            TextColor="#96979B"
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />
                    </Grid>

                    <!-- Success icon -->
                    <Grid
                        IsVisible="{Binding IsSuccess, Source={x:Reference ThisView}}"
                        WidthRequest="140"
                        HeightRequest="140">

                        <Ellipse
                            Stroke="#96979B"
                            StrokeThickness="2.5"
                            WidthRequest="100"
                            HeightRequest="100"
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />

                        <Label
                            Text="·   ·"
                            FontFamily="{StaticResource FontSFRegular}"
                            FontSize="28"
                            TextColor="#96979B"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            Margin="0,-24,0,0" />

                        <BoxView
                            WidthRequest="46"
                            HeightRequest="2"
                            BackgroundColor="#96979B"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            Margin="0,28,0,0" />
                    </Grid>

                    <!-- Confirm text -->
                    <VerticalStackLayout
                        Spacing="10"
                        IsVisible="{Binding IsSuccess, Source={x:Reference ThisView}, Converter={StaticResource InverseBoolConverter}}">

                        <Label
                            Text="Siz buyurtmani bekor qilyapsiz"
                            FontFamily="{StaticResource FontSFRegular}"
                            FontSize="17"
                            TextColor="#22292F"
                            HorizontalTextAlignment="Center" />

                        <Label
                            Text="Ishonchingiz komilmi?"
                            FontFamily="{StaticResource FontSFRegular}"
                            FontSize="17"
                            TextColor="#22292F"
                            HorizontalTextAlignment="Center" />

                    </VerticalStackLayout>

                    <!-- Success text -->
                    <VerticalStackLayout
                        Spacing="12"
                        IsVisible="{Binding IsSuccess, Source={x:Reference ThisView}}">

                        <Label
                            Text="Byurtma muvaffaqiyatli bekor qilindi"
                            FontFamily="{StaticResource FontSFRegular}"
                            FontSize="17"
                            TextColor="#22292F"
                            WidthRequest="260"
                            HorizontalTextAlignment="Center" />

                        <Label
                            Text="Bekor qilingan buyurtma uchun to’langan mablag’ hisob raqamingizga 3 kun muddatda qaytariladi"
                            FontFamily="{StaticResource FontSFRegular}"
                            FontSize="17"
                            TextColor="#96979B"
                            WidthRequest="260"
                            HorizontalTextAlignment="Center" />

                    </VerticalStackLayout>

                </VerticalStackLayout>

                <!-- Confirm buttons -->
                <VerticalStackLayout
                    Spacing="14"
                    IsVisible="{Binding IsSuccess, Source={x:Reference ThisView}, Converter={StaticResource InverseBoolConverter}}">

                    <Button
                        Text="Tasdiqlayman"
                        HeightRequest="56"
                        CornerRadius="40"
                        BackgroundColor="#DADADA"
                        TextColor="#22292F"
                        FontFamily="{StaticResource FontSFMedium}"
                        FontSize="18"
                        Clicked="OnConfirmClicked" />

                    <Button
                        Text="Bekor qilmayman"
                        HeightRequest="56"
                        CornerRadius="40"
                        BackgroundColor="#FD473C"
                        TextColor="White"
                        FontFamily="{StaticResource FontSFMedium}"
                        FontSize="18"
                        Clicked="OnDoNotCancelClicked" />

                </VerticalStackLayout>

                <!-- Success button -->
                <Button
                    IsVisible="{Binding IsSuccess, Source={x:Reference ThisView}}"
                    Text="Tushunarli"
                    HeightRequest="56"
                    CornerRadius="40"
                    BackgroundColor="#FD473C"
                    TextColor="White"
                    FontFamily="{StaticResource FontSFMedium}"
                    FontSize="18"
                    Clicked="OnOkClicked" />

            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentView>