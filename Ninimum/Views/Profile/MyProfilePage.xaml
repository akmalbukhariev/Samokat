<?xml version="1.0" encoding="utf-8" ?>
<page:BasePage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:page="clr-namespace:Ninimum.Views"
    xmlns:components="clr-namespace:Ninimum.Components"
    x:Class="Ninimum.Views.Profile.MyProfilePage"
    x:Name="ThisPage"
    BackgroundColor="White">

    <page:BasePage.Resources>
        <ResourceDictionary>

            <Style x:Key="ProfileMenuTextStyle" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource FontSFRegular}" />
                <Setter Property="FontSize" Value="17" />
                <Setter Property="TextColor" Value="#22292F" />
                <Setter Property="VerticalTextAlignment" Value="Center" />
            </Style>

            <Style x:Key="ProfileBadgeTextStyle" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource FontSFMedium}" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="#96979B" />
            </Style>

            <Style x:Key="ProfileGreenValueStyle" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource FontSFRegular}" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="TextColor" Value="#7CB518" />
                <Setter Property="VerticalTextAlignment" Value="Center" />
            </Style>

        </ResourceDictionary>
    </page:BasePage.Resources>

    <Grid>
        <ScrollView VerticalScrollBarVisibility="Never">
        <VerticalStackLayout Padding="20,70,20,24" Spacing="0">

            <!-- User -->
            <Label
                Text="Eshmatov Toshmat"
                FontFamily="{StaticResource FontSFMedium}"
                FontSize="24"
                TextColor="#22292F" />

            <HorizontalStackLayout Margin="0,4,0,40" Spacing="12">
                <Label
                    Text="+998 88 888 88 88"
                    FontFamily="{StaticResource FontSFRegular}"
                    FontSize="15"
                    TextColor="#22292F"
                    VerticalOptions="Center" />

                <Border
                    Padding="12,2"
                    BackgroundColor="#7CB518"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20">
                    <Label
                        Text="Tasdiqlangan"
                        FontFamily="{StaticResource FontSFMedium}"
                        FontSize="14"
                        TextColor="White" />
                </Border>
            </HorizontalStackLayout>

            <!-- Main menu -->
            <VerticalStackLayout Spacing="30">

                <Grid ColumnDefinitions="32,10,*,Auto,24">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OrderCommand}" />
                    </Grid.GestureRecognizers>

                    <Image Source="ic_order.png" WidthRequest="24" HeightRequest="24" />
                    <Label Grid.Column="2" Text="Buyurtma" Style="{StaticResource ProfileMenuTextStyle}" />

                    <Border Grid.Column="3" Padding="10,2" BackgroundColor="#F7FBEF" StrokeThickness="0" StrokeShape="RoundRectangle 20">
                        <Label Text="2/1" Style="{StaticResource ProfileBadgeTextStyle}" />
                    </Border>

                    <Image Grid.Column="4" Source="ic_arrow_right.png" WidthRequest="16" HeightRequest="16" />
                </Grid>

                <Grid ColumnDefinitions="32,10,*,Auto,24">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ReviewCommand}" />
                    </Grid.GestureRecognizers>

                    <Image Source="ic_comment.png" WidthRequest="24" HeightRequest="24" />
                    <Label Grid.Column="2" Text="Sharh" Style="{StaticResource ProfileMenuTextStyle}" />

                    <Border Grid.Column="3" Padding="10,2" BackgroundColor="#F7FBEF" StrokeThickness="0" StrokeShape="RoundRectangle 20">
                        <Label Text="2/1" Style="{StaticResource ProfileBadgeTextStyle}" />
                    </Border>

                    <Image Grid.Column="4" Source="ic_arrow_right.png" WidthRequest="16" HeightRequest="16" />
                </Grid>

                <Grid ColumnDefinitions="32,10,*,Auto,24">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding PaymentCardCommand}" />
                    </Grid.GestureRecognizers>

                    <Image Source="ic_payment_card.png" WidthRequest="24" HeightRequest="24" />
                    <Label Grid.Column="2" Text="To’lov karta" Style="{StaticResource ProfileMenuTextStyle}" />

                    <Border Grid.Column="3" Padding="10,2" BackgroundColor="#F7FBEF" StrokeThickness="0" StrokeShape="RoundRectangle 20">
                        <Label Text="2" Style="{StaticResource ProfileBadgeTextStyle}" />
                    </Border>

                    <Image Grid.Column="4" Source="ic_arrow_right.png" WidthRequest="16" HeightRequest="16" />
                </Grid>

                <Grid ColumnDefinitions="32,10,*,Auto,24">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding MessageCommand}" />
                    </Grid.GestureRecognizers>

                    <Image Source="ic_message.png" WidthRequest="24" HeightRequest="24" />
                    <Label Grid.Column="2" Text="Yozishma" Style="{StaticResource ProfileMenuTextStyle}" />

                    <Border Grid.Column="3" Padding="10,2" BackgroundColor="#F7FBEF" StrokeThickness="0" StrokeShape="RoundRectangle 20">
                        <Label Text="10" Style="{StaticResource ProfileBadgeTextStyle}" />
                    </Border>

                    <Image Grid.Column="4" Source="ic_arrow_right.png" WidthRequest="16" HeightRequest="16" />
                </Grid>

                <Grid ColumnDefinitions="32,10,*,Auto,24">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NotificationCommand}" />
                    </Grid.GestureRecognizers>

                    <Image Source="ic_notification1.png" WidthRequest="24" HeightRequest="24" />
                    <Label Grid.Column="2" Text="Xabarnoma" Style="{StaticResource ProfileMenuTextStyle}" />

                    <Border Grid.Column="3" Padding="10,2" BackgroundColor="#F7FBEF" StrokeThickness="0" StrokeShape="RoundRectangle 20">
                        <Label Text="15" Style="{StaticResource ProfileBadgeTextStyle}" />
                    </Border>

                    <Image Grid.Column="4" Source="ic_arrow_right.png" WidthRequest="16" HeightRequest="16" />
                </Grid>

                <!-- Settings header -->
                <Grid ColumnDefinitions="32,10,*,24">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleSettingsCommand}" />
                    </Grid.GestureRecognizers>

                    <Image Source="ic_setting.png" WidthRequest="24" HeightRequest="24" />
                    <Label Grid.Column="2" Text="Sozlama" Style="{StaticResource ProfileMenuTextStyle}" />
                    <Image Grid.Column="3" Source="{Binding SettingsArrowIcon}" WidthRequest="16" HeightRequest="16" />
                </Grid>

            </VerticalStackLayout>

            <!-- Settings section -->
            <VerticalStackLayout
                Margin="64,24,0,0"
                Spacing="28"
                IsVisible="{Binding IsSettingsExpanded}">

                <Grid ColumnDefinitions="*,Auto,24">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding RegionCommand}" />
                    </Grid.GestureRecognizers>

                    <Label Text="Region" Style="{StaticResource ProfileMenuTextStyle}" />
                    <Label Grid.Column="1" Text="Qashqadaryo" Style="{StaticResource ProfileGreenValueStyle}" />
                    <Image Grid.Column="2" Source="ic_arrow_right.png" WidthRequest="16" HeightRequest="16" />
                </Grid>

                <Grid ColumnDefinitions="*,Auto,24">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding LanguageCommand}" />
                    </Grid.GestureRecognizers>

                    <Label Text="Til" Style="{StaticResource ProfileMenuTextStyle}" />

                    <Image
                        Grid.Column="1"
                        Source="{Binding SelectedLanguageFlag}"
                        WidthRequest="28"
                        HeightRequest="18"
                        Aspect="AspectFit" />

                    <Image Grid.Column="2" Source="ic_arrow_right.png" WidthRequest="16" HeightRequest="16" />
                </Grid>

                <Grid ColumnDefinitions="*,Auto,24">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ThemeCommand}" />
                    </Grid.GestureRecognizers>

                    <Label Text="Ko’rinish rejimi" Style="{StaticResource ProfileMenuTextStyle}" />
                    <Label Grid.Column="1" Text="Yorqin" Style="{StaticResource ProfileGreenValueStyle}" />
                    <Image Grid.Column="2" Source="ic_arrow_right.png" WidthRequest="16" HeightRequest="16" />
                </Grid>

                <Grid ColumnDefinitions="*,Auto,24">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ChangePhoneCommand}" />
                    </Grid.GestureRecognizers>

                    <Label Text="Telefon raqamni o’zgartirish" Style="{StaticResource ProfileMenuTextStyle}" />
                    <Label Grid.Column="1" Text="...888888" Style="{StaticResource ProfileGreenValueStyle}" />
                    <Image Grid.Column="2" Source="ic_arrow_right.png" WidthRequest="16" HeightRequest="16" />
                </Grid>

                <Grid ColumnDefinitions="*,24">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ChangePasswordCommand}" />
                    </Grid.GestureRecognizers>

                    <Label Text="Parolni o’zgartirish" Style="{StaticResource ProfileMenuTextStyle}" />
                    <Image Grid.Column="1" Source="ic_arrow_right.png" WidthRequest="16" HeightRequest="16" />
                </Grid>

                <Grid ColumnDefinitions="*,Auto,24">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding MyTariffCommand}" />
                    </Grid.GestureRecognizers>

                    <Label Text="Mening tarifim" Style="{StaticResource ProfileMenuTextStyle}" />
                    <Label Grid.Column="1" Text="Gold" Style="{StaticResource ProfileGreenValueStyle}" />
                    <Image Grid.Column="2" Source="ic_arrow_right.png" WidthRequest="16" HeightRequest="16" />
                </Grid>

                <Grid ColumnDefinitions="*,Auto,24">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ChildrenCommand}" />
                    </Grid.GestureRecognizers>

                    <Label Text="Farzandlarim" Style="{StaticResource ProfileMenuTextStyle}" />
                    <Label Grid.Column="1" Text="3" Style="{StaticResource ProfileGreenValueStyle}" />
                    <Image Grid.Column="2" Source="ic_arrow_right.png" WidthRequest="16" HeightRequest="16" />
                </Grid>

                <Label
                    Text="Akkauntni o’chirib yuborish"
                    FontFamily="{StaticResource FontSFRegular}"
                    FontSize="17"
                    TextColor="#EA1111">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding DeleteAccountCommand}" />
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>

            <!-- Logout -->
            <Border
                Margin="0,30,0,0"
                Padding="24,14"
                BackgroundColor="#FEF1F2"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 12">

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding LogoutCommand}" />
                </Border.GestureRecognizers>

                <HorizontalStackLayout Spacing="18">
                    <Image Source="ic_logout.png" WidthRequest="24" HeightRequest="24" />

                    <Label
                        Text="Profildan chiqish"
                        FontFamily="{StaticResource FontSFRegular}"
                        FontSize="17"
                        TextColor="#EA1111"
                        VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
        <components:QuestionPopupView
                x:Name="logOutPopup"
                QuestionTitle="Siz profildan chiqayapsiz.&#10;Ishonchingiz komilmi?"
                YesText="Ha, chiqaman"
                NoText="Yo’q, chiqmayman"
                SuccessTitle=""
                SuccessMessage=""
                OkText=""
                IsVisible="False"
                ZIndex="99" />
    </Grid>
</page:BasePage>