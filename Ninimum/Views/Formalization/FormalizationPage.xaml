<?xml version="1.0" encoding="utf-8" ?>
<page:BasePage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:page="clr-namespace:Ninimum.Views"
    xmlns:components="clr-namespace:Ninimum.Components"
    x:Class="Ninimum.Views.Formalization.FormalizationPage"
    x:Name="ThisPage"
    BackgroundColor="White">

    <Grid RowDefinitions="Auto,20,*, 10, Auto, 5">

        <components:PageHeaderView Title="Rasmiylashtirish" />

        <ScrollView Grid.Row="2">
            <VerticalStackLayout Padding="10,0,10,40" Spacing="24">

                <Label
                    Text="Qabul qilish usuli"
                    FontSize="22"
                    TextColor="#22292F"
                    FontFamily="{StaticResource FontSFMedium}" />

                <Grid
                    ColumnDefinitions="*,*"
                    Padding="3"
                    BackgroundColor="#F7F8FB"
                    HeightRequest="60">

                    <Border
                        x:Name="PickupTabBorder"
                        Grid.Column="0"
                        BackgroundColor="White"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 7"
                        Padding="10,6">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPickupTabTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="0" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label
                                Text="Topshirish punkti"
                                FontSize="14"
                                TextColor="#22292F"
                                FontFamily="{StaticResource FontSFMedium}" />
                            <Label
                                x:Name="PickupTabSubtitleLabel"
                                Text="Bepul"
                                FontSize="14"
                                TextColor="#21C940"
                                FontFamily="{StaticResource FontSFRegular}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        x:Name="CourierTabBorder"
                        Grid.Column="1"
                        BackgroundColor="#F7F8FB"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 7"
                        Padding="10,6">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCourierTabTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="0" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label
                                Text="Kuryer"
                                FontSize="14"
                                TextColor="#22292F"
                                FontFamily="{StaticResource FontSFMedium}" />
                            <Label
                                x:Name="CourierTabSubtitleLabel"
                                Text="30 000 so’m"
                                FontSize="14"
                                TextColor="#96979B"
                                FontFamily="{StaticResource FontSFRegular}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <HorizontalStackLayout Spacing="12">
                    <Image Source="location.png" WidthRequest="20" HeightRequest="20" />
                    <Label
                        x:Name="AddressLabel"
                        Text="Qashqadaryo viloyati, Shahrisabz shahar, Mo’ljal: 25-maktab"
                        FontSize="17"
                        TextColor="#22292F"
                        FontFamily="{StaticResource FontSFRegular}"
                        LineBreakMode="WordWrap" />
                </HorizontalStackLayout>

                <Label
                    x:Name="DeliveryInfoLabel"
                    Text="1 soatda yetkazib beramiz"
                    FontSize="14"
                    TextColor="#7CB518"
                    FontFamily="{StaticResource FontSFRegular}" />

                <Border
                    BackgroundColor="#FFF2F3"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 40"
                    HeightRequest="36"
                    HorizontalOptions="Fill">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnChangeAddressTapped" />
                    </Border.GestureRecognizers>

                    <Label
                        Text="Manzilni o’zgartirish"
                        TextColor="#FD473C"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        FontSize="15"
                        FontFamily="{StaticResource FontSFMedium}" />
                </Border>

                <Label
                    Text="Xarid qilinayotgan mahsulotlar"
                    FontSize="22"
                    TextColor="#22292F"
                    FontFamily="{StaticResource FontSFMedium}" />

                <CollectionView
                    x:Name="ProductsCollectionView"
                    ItemsSource="{Binding Products}"
                    SelectionMode="None"
                    HeightRequest="80">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                WidthRequest="80"
                                HeightRequest="80"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 4">
                                <Image
                                    Source="{Binding ImageSource}"
                                    Aspect="AspectFill"
                                    WidthRequest="80"
                                    HeightRequest="80" />
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label
                    Text="To’lov usuli"
                    FontSize="22"
                    TextColor="#22292F"
                    FontFamily="{StaticResource FontSFMedium}" />

                <Grid
                    ColumnDefinitions="*,*"
                    Padding="3"
                    BackgroundColor="#F7F8FB">

                    <Border
                        x:Name="OnlinePaymentTabBorder"
                        Grid.Column="0"
                        BackgroundColor="White"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 7"
                        Padding="10">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOnlinePaymentTabTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                            <Label
                                Text="Karta orqali onlayn"
                                FontSize="14"
                                FontFamily="{StaticResource FontSFMedium}" />
                            <Label
                                Text="UZCARD, HUMO, Visa"
                                FontSize="14"
                                TextColor="#96979B"
                                FontFamily="{StaticResource FontSFRegular}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        x:Name="CashPaymentTabBorder"
                        Grid.Column="1"
                        BackgroundColor="#F7F8FB"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 7"
                        Padding="10">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCashPaymentTabTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                            <Label
                                Text="Buyurtmani olganda"
                                FontSize="14"
                                FontFamily="{StaticResource FontSFMedium}" />
                            <Label
                                Text="Naqt yoki karta usulda"
                                FontSize="14"
                                TextColor="#96979B"
                                FontFamily="{StaticResource FontSFRegular}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <CollectionView
                    x:Name="CardsCollectionView"
                    ItemsSource="{Binding Cards}"
                    SelectionMode="None"
                    HeightRequest="94">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid>

                                <!-- Normal bank card -->
                                <Border
                                    WidthRequest="150"
                                    HeightRequest="94"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 10"
                                    IsVisible="{Binding IsAddCard, Converter={StaticResource InverseBoolConverter}}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnCardTapped" CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                                            <GradientStop Color="#32D994" Offset="0" />
                                            <GradientStop Color="#107096" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>

                                    <Grid Padding="10">
                                        <Image
                                            Source="{Binding RadioImage}"
                                            WidthRequest="24"
                                            HeightRequest="24"
                                            HorizontalOptions="End"
                                            VerticalOptions="Start" />

                                        <Label
                                            Text="{Binding CardNumber}"
                                            TextColor="White"
                                            FontSize="16"
                                            FontFamily="{StaticResource FontSFBold}"
                                            VerticalOptions="End" />
                                    </Grid>
                                </Border>

                                <!-- Add card item -->
                                <Border
                                    WidthRequest="94"
                                    HeightRequest="94"
                                    BackgroundColor="#F7F8FB"
                                    Stroke="#DADADA"
                                    StrokeShape="RoundRectangle 10"
                                    IsVisible="{Binding IsAddCard}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnAddCardTapped" />
                                    </Border.GestureRecognizers>

                                    <VerticalStackLayout
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"
                                        Spacing="6">
                                        <Label
                                            Text="+"
                                            FontSize="24"
                                            TextColor="#96979B"
                                            HorizontalOptions="Center" />

                                        <Label
                                            Text="Yangi karta qo’shish"
                                            FontSize="13"
                                            TextColor="#22292F"
                                            HorizontalTextAlignment="Center"
                                            FontFamily="{StaticResource FontSFRegular}" />
                                    </VerticalStackLayout>
                                </Border>

                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label
                    Text="Buyurtma tavsiloti"
                    FontSize="22"
                    TextColor="#22292F"
                    FontFamily="{StaticResource FontSFMedium}" />

                <Grid ColumnDefinitions="*,Auto">
                    <Label
                        x:Name="ProductsCountLabel"
                        Text="Mahsulotlar soni: 2 ta"
                        FontSize="17"
                        FontFamily="{StaticResource FontSFRegular}" />
                    <Label
                        x:Name="ProductsPriceLabel"
                        Text="545 000 so’m"
                        Grid.Column="1"
                        FontSize="17"
                        FontFamily="{StaticResource FontSFMedium}" />
                </Grid>

                <Grid ColumnDefinitions="*,Auto">
                    <Label
                        Text="Yetkazib berish"
                        FontSize="17"
                        FontFamily="{StaticResource FontSFRegular}" />
                    <Label
                        x:Name="DeliveryPriceLabel"
                        Text="0 so’m"
                        Grid.Column="1"
                        FontSize="17"
                        FontFamily="{StaticResource FontSFMedium}" />
                </Grid>

                <BoxView HeightRequest="1" BackgroundColor="#DADADA" />

                <Grid ColumnDefinitions="*,Auto">
                    <Label
                        Text="Jami to’lov"
                        FontSize="17"
                        FontFamily="{StaticResource FontSFRegular}" />
                    <Label
                        x:Name="TotalPriceLabel"
                        Text="545 000 so’m"
                        Grid.Column="1"
                        FontSize="22"
                        FontFamily="{StaticResource FontSFMedium}" />
                </Grid>

                <Label
                    FontSize="13"
                    TextColor="#96979B"
                    LineBreakMode="WordWrap"
                    FontFamily="{StaticResource FontSFRegular}">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Buyurtmani amalga oshirish vaqtida siz, shaxsga doir ma’lumotlar " />
                            <Span Text="Maxfiylik kelishuviga" TextDecorations="Underline" />
                            <Span Text=" muvofiq qayta ishlatishga rozilik bildirasiz hamda, " />
                            <Span Text="Foydalanuvchi kelishuvini qabul qilasiz." TextDecorations="Underline" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

            </VerticalStackLayout>
        </ScrollView>
        <Button
            Grid.Row="4"
            Text="Buyurtmani rasmiylashtirish"
            FontFamily="{StaticResource FontSFMedium}"
            FontSize="18"
            CornerRadius="8"
            HeightRequest="54"
            Margin="14, 0, 14, 0"
            BackgroundColor="#FD473C"/>
    </Grid>
</page:BasePage>