<?xml version="1.0" encoding="utf-8" ?>
<page:BasePage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:page="clr-namespace:Samokat.Views"
    xmlns:components="clr-namespace:Samokat.Components"
    x:Class="Samokat.Views.ChangePhoneNumber.ChangePhoneNumberPage"
    x:Name="ThisPage"
    BackgroundColor="White">

    <Grid RowDefinitions="Auto,*, Auto">

        <!-- Header -->
        <components:PageHeaderView
            Grid.Row="0"
            Title="Telefon raqamini o’zgartirish" />

        <ScrollView Grid.Row="1">

            <VerticalStackLayout
                Padding="20,24,20,24"
                Spacing="24">

                <!-- Current phone -->
                <VerticalStackLayout Spacing="0">
                    <Label
                        Text="Sizning amaldagi telefon raqamingiz"
                        FontFamily="{StaticResource FontSFRegular}"
                        FontSize="17"
                        TextColor="#96979B" />

                    <Label
                        Text="{Binding CurrentPhoneNumber}"
                        FontFamily="{StaticResource FontSFRegular}"
                        FontSize="17"
                        TextColor="#7CB518" />
                </VerticalStackLayout>

                <!-- Description -->
                <Label
                    Text="Iltimos, yangi telefon raqamingizni kiriting"
                    FontFamily="{StaticResource FontSFRegular}"
                    FontSize="17"
                    TextColor="#22292F" />

                <!-- Warning -->
                <Border
                    Padding="10"
                    BackgroundColor="#FFF2F3"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 8">

                    <Label
                        Text="Diqqat! Birovning ma’lumotlaridan noqonuniy tarzda foydalanish qonun buzilishi holatiga olib kelishi mumkin."
                        FontFamily="{StaticResource FontSFRegular}"
                        FontSize="13"
                        TextColor="#EA1111" />
                </Border>

                <!-- Inputs -->
                <VerticalStackLayout Spacing="14">

                    <components:InputView
                        Title="Telefon raqam"
                        LeftIcon="ic_phone.png"
                        Keyboard="Telephone"
                        ClearButtonVisibility="WhileEditing"
                        Text="{Binding PhoneNumber}" />

                    <components:InputView
                        Placeholder="*****"
                        LeftIcon="ic_lock.png"
                        IsPassword="True"
                        EnablePasswordToggle="True"
                        PasswordHideIcon="ic_eye_off.png"
                        PasswordShowIcon="ic_eye_on.png"
                        Text="{Binding Password}" />

                </VerticalStackLayout>

                <!-- Agreement -->
                <Grid
                    ColumnDefinitions="24,*"
                    ColumnSpacing="12">

                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleAgreementCommand}" />
                    </Grid.GestureRecognizers>

                    <Image
                        Source="{Binding AgreementIcon}"
                        WidthRequest="24"
                        HeightRequest="24"
                        VerticalOptions="Center" />

                    <Label
                        Grid.Column="1"
                        Text="Barcha to’ldirilgan ma’lumotlar to’g’riligini kafolatlayman"
                        FontFamily="{StaticResource FontSFRegular}"
                        FontSize="17"
                        TextColor="#22292F"
                        LineBreakMode="WordWrap" />
                </Grid>

            </VerticalStackLayout>

        </ScrollView>
    
        <Button
            Grid.Row="2"
            Text="O’zgartirish"
            HeightRequest="56"
            CornerRadius="8"
            Margin="15,0,15,24"
            BackgroundColor="#7CB518"
            TextColor="White"
            FontFamily="{StaticResource FontSFMedium}"
            FontSize="18"/>
    </Grid>
</page:BasePage>