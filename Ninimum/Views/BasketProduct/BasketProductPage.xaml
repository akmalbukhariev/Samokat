<?xml version="1.0" encoding="utf-8" ?>
<page:BasePage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:page="clr-namespace:Ninimum.Views"
    xmlns:components="clr-namespace:Ninimum.Components"
    xmlns:local="clr-namespace:Ninimum.Views.BasketProduct"
    x:Class="Ninimum.Views.BasketProduct.BasketProductPage"
    x:Name="ThisPage"
    BackgroundColor="White">

    <Grid
        Padding="20,0,20,20"
        RowDefinitions="Auto,Auto,*,10,Auto">
        
        <!-- Header -->
        <components:PageHeaderView
            Grid.Row="0"
            ShowBack="false"
            Title="Savatcha" />

        <!-- Top actions -->
        <Grid
            Grid.Row="1"
            Margin="0,22,0,18"
            ColumnDefinitions="*,Auto,Auto"
            ColumnSpacing="12">

            <Label
                VerticalOptions="Center"
                Text="{Binding BasketCountText}"
                TextColor="#96979B"
                FontSize="16"
                FontFamily="{StaticResource FontSFRegular}" />

            <Border
                Grid.Column="1"
                Padding="16"
                BackgroundColor="#FDEEEE"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 14">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding DeleteSelectedCommand}" />
                </Border.GestureRecognizers>

                <Image
                    Source="ic_delete.png"
                    Aspect="AspectFit"
                    WidthRequest="24"
                    HeightRequest="24" />
            </Border>

            <Border
                Grid.Column="2"
                Padding="16"
                BackgroundColor="#F1F2F6"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 14">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ToggleSelectAllCommand}" />
                </Border.GestureRecognizers>

                <Image
                    Source="{Binding SelectAllIcon}"
                    Aspect="AspectFit"
                    WidthRequest="24"
                    HeightRequest="24" />
            </Border>
        </Grid>
        <CollectionView
            Grid.Row="2"
            ItemsSource="{Binding BasketProducts}"
            SelectionMode="None"
            VerticalOptions="FillAndExpand">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="16" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <local:BasketCartItemView
                        ProductImageSource="{Binding ProductImageSource}"
                        Title="{Binding Title}"
                        OldPrice="{Binding OldPrice}"
                        NewPrice="{Binding NewPrice}"
                        IsChecked="{Binding IsChecked, Mode=TwoWay}"
                        Quantity="{Binding Quantity, Mode=TwoWay}"
                        QuantityChangedCommand="{Binding QuantityChangedCommand}"
                        ToggleCheckedCommand="{Binding ToggleCheckedCommand}" />
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.Footer>
                <Border
                    Margin="0,20,0,0"
                    Padding="18"
                    BackgroundColor="#F6EAEA"
                    Stroke="#FF4A3F"
                    StrokeThickness="1.2"
                    StrokeShape="RoundRectangle 18">

                    <VerticalStackLayout Spacing="18">

                        <VerticalStackLayout Spacing="10">
                            <Label
                                Text="{Binding SummaryTopText}"
                                TextColor="#22292F"
                                FontSize="18"
                                FontFamily="{StaticResource FontSFMedium}" />

                            <Label>
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span
                                            Text="{Binding TotalSelectedPrice}"
                                            FontSize="28"
                                            FontFamily="{StaticResource FontSFBold}"
                                            TextColor="#22292F" />
                                        <Span
                                            Text=" so’mga xarid qilishingiz mumkin."
                                            FontSize="18"
                                            FontFamily="{StaticResource FontSFRegular}"
                                            TextColor="#22292F" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Label
                                Text="Buning uchun siz Tarif rejasiga ulanishingiz kerak bo’ladi."
                                TextColor="#22292F"
                                FontSize="17"
                                FontFamily="{StaticResource FontSFRegular}"
                                LineBreakMode="WordWrap" />

                            <Label
                                Text="Iltimos birorta Tarif rejasini tanlang va maxsus chegirmalarga ega bo’ling"
                                TextColor="#22292F"
                                FontSize="17"
                                FontFamily="{StaticResource FontSFRegular}"
                                LineBreakMode="WordWrap" />
                        </VerticalStackLayout>

                        <Button
                            Text="Tarifga azo bo’lish"
                            HeightRequest="64"
                            CornerRadius="16"
                            BackgroundColor="#FF4A3F"
                            TextColor="White"
                            FontSize="18"
                            FontFamily="{StaticResource FontSFBold}"
                            Command="{Binding JoinTariffCommand}" />
                    </VerticalStackLayout>
                </Border>
            </CollectionView.Footer>
        </CollectionView>

        <!-- Fixed bottom bar -->
        <Grid
            Grid.Row="4"
            Padding="8,0"
            ColumnDefinitions="*,Auto"
            VerticalOptions="Center"
            BackgroundColor="White">

            <VerticalStackLayout
                Grid.Column="0"
                Spacing="0"
                VerticalOptions="Center">

                <Label
                    Text="545 000 so’m"
                    TextColor="#22292F"
                    FontSize="24"
                    FontFamily="{StaticResource FontSFMedium}"
                    FontAttributes="None" />

                <Label
                    Text="1 ta mahsulot"
                    TextColor="#96979B"
                    FontSize="17"
                    FontFamily="{StaticResource FontSFRegular}"
                    FontAttributes="None" />
            </VerticalStackLayout>

            <Button
                Grid.Column="1"
                Text="Rasmiylashtirish"
                FontSize="18"
                TextColor="White"
                FontFamily="{StaticResource FontSFMedium}"
                HeightRequest="54"
                Padding="14,0"
                BackgroundColor="#FD473C"
                CornerRadius="8"
                VerticalOptions="Center" />
        </Grid>
    </Grid>
</page:BasePage>