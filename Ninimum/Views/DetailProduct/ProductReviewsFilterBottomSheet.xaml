<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:Samokat.Components"
    x:Class="Samokat.Views.DetailProduct.ProductReviewsFilterBottomSheet"
    x:Name="ThisView"
    IsVisible="False"
    InputTransparent="False">

    <Grid RowDefinitions="*,Auto">

        <BoxView
            x:Name="Backdrop"
            Grid.RowSpan="2"
            BackgroundColor="#66000000"
            InputTransparent="False" />

        <Border
            x:Name="SheetContainer"
            Grid.Row="1"
            BackgroundColor="#F7F7F7"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 30,30,0,0"
            TranslationY="900"
            VerticalOptions="End"
            HorizontalOptions="Fill">

            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="SheetContainer_Tapped" />
            </Border.GestureRecognizers>

            <Grid
                Padding="24,14,24,34"
                RowDefinitions="Auto,18,Auto,24,Auto,24,1,24,Auto,28,Auto"
                RowSpacing="0">

                <Grid
                    x:Name="DragArea"
                    Grid.Row="0"
                    HeightRequest="26">

                    <Border
                        WidthRequest="82"
                        HeightRequest="6"
                        BackgroundColor="#D0D0D0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 3"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                </Grid>

                <Label
                    Grid.Row="2"
                    Text="Saralash"
                    FontSize="22"
                    FontFamily="{StaticResource FontSFBold}"
                    TextColor="#22292F"
                    CharacterSpacing="0.22" />

                <VerticalStackLayout
                    Grid.Row="4"
                    Spacing="0">

                    <Grid Padding="0,12" ColumnDefinitions="*,Auto">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding SelectSortCommand}"
                                CommandParameter="newest" />
                        </Grid.GestureRecognizers>

                        <Label
                            Text="Avval yangilari"
                            VerticalOptions="Center"
                            FontSize="17"
                            FontFamily="{StaticResource FontSFRegular}"
                            TextColor="#22292F"
                            CharacterSpacing="0.17" />

                        <components:CustomRadioButtonView
                            Grid.Column="1"
                            IsSelected="{Binding IsSortNewestFirst}"
                            Command="{Binding SelectSortCommand}"
                            CommandParameter="newest"
                            SelectedColor="#21C940"
                            UnselectedColor="#96979B"
                            TextColor="Transparent"
                            Text="" />
                    </Grid>

                    <Grid Padding="0,12" ColumnDefinitions="*,Auto">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding SelectSortCommand}"
                                CommandParameter="high" />
                        </Grid.GestureRecognizers>

                        <Label
                            Text="Avval bahosi yuqorilari"
                            VerticalOptions="Center"
                            FontSize="17"
                            FontFamily="{StaticResource FontSFRegular}"
                            TextColor="#22292F"
                            CharacterSpacing="0.17" />

                        <components:CustomRadioButtonView
                            Grid.Column="1"
                            IsSelected="{Binding IsSortRatingHighFirst}"
                            Command="{Binding SelectSortCommand}"
                            CommandParameter="high"
                            SelectedColor="#21C940"
                            UnselectedColor="#96979B"
                            TextColor="Transparent"
                            Text="" />
                    </Grid>

                    <Grid Padding="0,12" ColumnDefinitions="*,Auto">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding SelectSortCommand}"
                                CommandParameter="low" />
                        </Grid.GestureRecognizers>

                        <Label
                            Text="Avval bahosi pastlari"
                            VerticalOptions="Center"
                            FontSize="17"
                            FontFamily="{StaticResource FontSFRegular}"
                            TextColor="#22292F"
                            CharacterSpacing="0.17" />

                        <components:CustomRadioButtonView
                            Grid.Column="1"
                            IsSelected="{Binding IsSortRatingLowFirst}"
                            Command="{Binding SelectSortCommand}"
                            CommandParameter="low"
                            SelectedColor="#21C940"
                            UnselectedColor="#96979B"
                            TextColor="Transparent"
                            Text="" />
                    </Grid>
                </VerticalStackLayout>

                <BoxView
                    Grid.Row="6"
                    HeightRequest="1"
                    BackgroundColor="#D9D9D9"
                    VerticalOptions="Center" />

                <Grid
                    Grid.Row="8"
                    ColumnDefinitions="*,Auto"
                    VerticalOptions="Center">

                    <Label
                        Text="Faqat fotosuratlilari"
                        VerticalOptions="Center"
                        FontSize="17"
                        FontFamily="{StaticResource FontSFRegular}"
                        TextColor="#22292F"
                        CharacterSpacing="0.17" />

                    <Switch
                        Grid.Column="1"
                        IsToggled="{Binding IsPhotoOnly}"
                        OnColor="#21C940"
                        ThumbColor="White"
                        Scale="1.1"
                        VerticalOptions="Center" />
                </Grid>

                <Grid Grid.Row="10">
                    <components:CustomActionButton
                        ButtonText="Filtrlash"
                        ButtonBackgroundColor="#FD473C"
                        ButtonTextColor="White"
                        TapCommand="{Binding ApplyFilterCommand}" />
                </Grid>

            </Grid>
        </Border>
    </Grid>
</ContentView>