<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Samokat.Components.SelectionPopupItemView"
             x:Name="ThisView">

    <Grid RowDefinitions="72,1"
          ColumnDefinitions="*">

        <Grid Grid.Row="0"
              Padding="22,0"
              ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="14">

            <Image Grid.Column="0"
                   Source="{Binding LeftImage, Source={x:Reference ThisView}}"
                   WidthRequest="28"
                   HeightRequest="18"
                   VerticalOptions="Center"
                   IsVisible="{Binding HasLeftImage, Source={x:Reference ThisView}}" />

            <Label Grid.Column="1"
                   Text="{Binding Text, Source={x:Reference ThisView}}"
                   FontSize="17"
                   FontFamily="{StaticResource FontSFRegular}"
                   TextColor="{StaticResource InputTextColor}"
                   VerticalTextAlignment="Center"
                   VerticalOptions="Center"/>

            <Image Grid.Column="2"
                   Source="{Binding RightImage, Source={x:Reference ThisView}}"
                   WidthRequest="20"
                   HeightRequest="20"
                   VerticalOptions="Center"
                   IsVisible="{Binding HasRightImage, Source={x:Reference ThisView}}" />
        </Grid>

        <BoxView Grid.Row="1"
                 Color="#D9D9D9" />
    </Grid>
</ContentView>