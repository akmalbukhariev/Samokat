<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Samokat.Components.InputView"
             x:Name="ThisView">

    <Border
        StrokeThickness="0"
        BackgroundColor="{StaticResource InputBackground}"
        HeightRequest="60"
        StrokeShape="RoundRectangle 30">
        
         <Border.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding TapCommand, Source={x:Reference ThisView}}" />
        </Border.GestureRecognizers>

        <Grid
            Padding="0,0"
            ColumnDefinitions="Auto,Auto,*,Auto"
            ColumnSpacing="12"
            VerticalOptions="Center">

            <!-- Left Icon -->
            <Image
                Grid.Column="0"
                Source="{Binding LeftIcon, Source={x:Reference ThisView}}"
                HeightRequest="28"
                WidthRequest="28"
                VerticalOptions="Center"
                IsVisible="{Binding HasLeftIcon, Source={x:Reference ThisView}}" />

            <!-- Flag / Middle Image -->
            <Image
                Grid.Column="1"
                Source="{Binding MiddleImage, Source={x:Reference ThisView}}"
                HeightRequest="18"
                WidthRequest="28"
                VerticalOptions="Center"
                IsVisible="{Binding HasMiddleImage, Source={x:Reference ThisView}}" />

            <!-- Text Area -->
            <Grid
                Grid.Column="2"
                ColumnDefinitions="Auto,*"
                ColumnSpacing="10"
                VerticalOptions="Center">

                <Label
                    Grid.Column="0"
                    Text="{Binding Title, Source={x:Reference ThisView}}"
                    FontSize="17"
                    TextColor="{StaticResource InputPlaceholderColor}"
                    VerticalTextAlignment="Center"
                    IsVisible="{Binding HasTitle, Source={x:Reference ThisView}}" />

                <Entry
                    Grid.Column="1"
                    Text="{Binding Text, Source={x:Reference ThisView}, Mode=TwoWay}"
                    Placeholder="{Binding Placeholder, Source={x:Reference ThisView}}"
                    FontSize="17"
                    TextColor="{StaticResource InputTextColor}"
                    PlaceholderColor="{StaticResource InputPlaceholderColor}"
                    BackgroundColor="Transparent"
                    IsReadOnly="{Binding IsReadOnly, Source={x:Reference ThisView}}"
                    InputTransparent="{Binding IsReadOnly, Source={x:Reference ThisView}}" />
            </Grid>

            <!-- Right Icon -->
            <Image
                Grid.Column="3"
                Source="{Binding RightIcon, Source={x:Reference ThisView}}"
                HeightRequest="18"
                WidthRequest="18"
                VerticalOptions="Center"
                IsVisible="{Binding HasRightIcon, Source={x:Reference ThisView}}" />

        </Grid>

    </Border>

</ContentView>