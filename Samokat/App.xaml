<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Samokat"
             x:Class="Samokat.App">
    <Application.Resources>
        <ResourceDictionary>
            <x:String x:Key="FontSFRegular">SFRegular</x:String>
            <x:String x:Key="FontSFMedium">SFMedium</x:String>
            <x:String x:Key="FontSFBold">SFBold</x:String>
            <x:String x:Key="FontSansitaOne">SansitaOne</x:String>
            
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
